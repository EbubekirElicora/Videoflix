# ============================================================
# VIDEOFLIX ENVIRONMENT CONFIGURATION
# ============================================================
#
# SETUP:
#
# 1. Copy this file and name the copy ".env".
#
# Linux, macOS or Git Bash:
# cp .env.template .env
#
# Windows PowerShell:
# Copy-Item .env.template .env
#
# 2. Edit only the new ".env" file.
# 3. Never commit the real ".env" file to GitHub.
# 4. Lines beginning with "#" are comments and are ignored.
#
# The active values below are configured for LOCAL DEVELOPMENT.
# Staging and production examples are included further below.
#
# Only one value for each variable may be active at the same time.


# ============================================================
# DJANGO ADMIN ACCOUNT
# ============================================================
#
# The Docker entrypoint automatically creates this administrator
# account when the user does not already exist.
#
# Local Django Admin:
# http://localhost:8000/admin/

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=adminpassword
DJANGO_SUPERUSER_EMAIL=admin@example.com


# ============================================================
# DJANGO CORE SETTINGS
# ============================================================
#
# This example secret key is intended only for local development.
# Replace it with a long random value for staging or production.

SECRET_KEY=change-this-secret-key-for-local-development


# ============================================================
# ENVIRONMENT PROFILE: LOCAL DEVELOPMENT
# ============================================================
#
# These values are active by default.
# They allow the frontend and backend to communicate locally.

DEBUG=True

ALLOWED_HOSTS=localhost,127.0.0.1

CSRF_TRUSTED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:5501,http://127.0.0.1:5501

CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:5501,http://127.0.0.1:5501


# Local development normally uses HTTP instead of HTTPS.

AUTH_COOKIE_SECURE=False
AUTH_COOKIE_SAMESITE=Lax
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0

# ============================================================
# BACKEND HOST PORT
# ============================================================
#
# Port used to open the backend on the host computer.
#
# Keep 8000 for the standard local setup:
# http://localhost:8000
#
# The application inside the Docker container still runs
# internally on port 8000.

WEB_PORT=8000


# ============================================================
# POSTGRESQL DATABASE
# ============================================================
#
# These local values work directly with docker-compose.yml.
#
# Keep DB_HOST=db when Docker Compose is used.
# "db" is the PostgreSQL service name inside Docker.

DB_NAME=videoflix_db
DB_USER=videoflix_user
DB_PASSWORD=videoflix_local_password
DB_HOST=db
DB_PORT=5432


# ============================================================
# REDIS AND DJANGO RQ
# ============================================================
#
# Keep REDIS_HOST=redis when Docker Compose is used.
# "redis" is the Redis service name inside Docker.
#
# Redis database 1 is used for the Django cache.
# Redis database 0 is used for Django RQ.

REDIS_HOST=redis
REDIS_LOCATION=redis://redis:6379/1
REDIS_PORT=6379
REDIS_DB=0


# ============================================================
# EMAIL CONFIGURATION
# ============================================================
#
# Choose exactly ONE email backend.
#
# OPTION A is active by default.
# OPTION B must be activated for real email delivery.


# ------------------------------------------------------------
# OPTION A: DISPLAY EMAILS IN THE DOCKER LOGS
# ACTIVE BY DEFAULT
# ------------------------------------------------------------
#
# No real email is sent with this backend.
#
# Activation and password-reset emails are displayed with:
#
# docker compose logs -f web
#
# This option does not require an email account or SMTP password.

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend


# ------------------------------------------------------------
# OPTION B: SEND REAL EMAILS THROUGH SMTP
# ------------------------------------------------------------
#
# To send real emails:
#
# 1. Add "#" before the active console backend above.
#
# 2. Remove "#" before the SMTP backend below.
#
# 3. Replace every SMTP placeholder with values from your
#    own email provider.
#
# The result must contain exactly one active EMAIL_BACKEND line.
#
# Example:
#
# # EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend


# Replace these example values when SMTP is activated.

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@example.com
EMAIL_HOST_PASSWORD=your_email_password


# Port 587 normally uses STARTTLS.

EMAIL_USE_TLS=True
EMAIL_USE_SSL=False


# Port 465 normally uses direct SSL instead:
#
# EMAIL_PORT=465
# EMAIL_USE_TLS=False
# EMAIL_USE_SSL=True
#
# EMAIL_USE_TLS and EMAIL_USE_SSL must never both be True.

DEFAULT_FROM_EMAIL=your_email@example.com


# Some email providers require an app password when
# two-factor authentication is enabled.
#
# In that case, enter the generated app password in:
#
# EMAIL_HOST_PASSWORD
#
# Never enter real credentials in this template file.
# Real credentials belong only in the local ".env" file.


# ============================================================
# FRONTEND URLS USED INSIDE EMAILS
# ============================================================
#
# These addresses are inserted into activation and
# password-reset emails.
#
# The port must match the port used by the frontend.
#
# The active defaults expect Live Server on port 5500.

FRONTEND_ACTIVATION_URL=http://127.0.0.1:5500/pages/auth/activate.html
FRONTEND_PASSWORD_RESET_URL=http://127.0.0.1:5500/pages/auth/confirm_password.html


# When Live Server runs on port 5501, use:
#
# FRONTEND_ACTIVATION_URL=http://127.0.0.1:5501/pages/auth/activate.html
# FRONTEND_PASSWORD_RESET_URL=http://127.0.0.1:5501/pages/auth/confirm_password.html


# ============================================================
# OPTIONAL STAGING PROFILE
# ============================================================
#
# To use staging:
#
# 1. Comment out the corresponding local-development values.
# 2. Uncomment the staging values below.
# 3. Replace every example domain.
# 4. Replace the secret key and passwords.
# 5. Activate and configure the SMTP email backend.
# 6. Use HTTPS.
#
# DEBUG=False
# ALLOWED_HOSTS=staging.example.com
# CSRF_TRUSTED_ORIGINS=https://staging.example.com
# CORS_ALLOWED_ORIGINS=https://staging.example.com
# AUTH_COOKIE_SECURE=True
# AUTH_COOKIE_SAMESITE=Lax
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=3600
# FRONTEND_ACTIVATION_URL=https://staging.example.com/pages/auth/activate.html
# FRONTEND_PASSWORD_RESET_URL=https://staging.example.com/pages/auth/confirm_password.html


# ============================================================
# OPTIONAL PRODUCTION PROFILE
# ============================================================
#
# To use production:
#
# 1. Comment out the corresponding local-development values.
# 2. Uncomment the production values below.
# 3. Replace every example domain.
# 4. Replace SECRET_KEY.
# 5. Replace database and administrator credentials.
# 6. Activate and configure the SMTP email backend.
# 7. Use HTTPS.
# 8. Never commit the production ".env" file.
#
# DEBUG=False
# ALLOWED_HOSTS=videoflix.example.com
# CSRF_TRUSTED_ORIGINS=https://videoflix.example.com
# CORS_ALLOWED_ORIGINS=https://videoflix.example.com
# AUTH_COOKIE_SECURE=True
# AUTH_COOKIE_SAMESITE=Lax
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=3600
# FRONTEND_ACTIVATION_URL=https://videoflix.example.com/pages/auth/activate.html
# FRONTEND_PASSWORD_RESET_URL=https://videoflix.example.com/pages/auth/confirm_password.html